rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Users collection
    match /users/{userId} {
      // Any authenticated user can read any user profile (for viewing profiles, search, posts)
      allow read: if request.auth != null;
      
      // Only the user can create their own user document at registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Admin can update any user field (e.g. decrement totalPosts on post deletion)
      allow update: if isAdmin();
      
      // Prevent users from modifying their role field (only manual admin assignment via Firebase Console)
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys());
      
      // Allow updating friends array when accepting friend requests
      allow update: if request.auth != null && 
        'friends' in request.resource.data.diff(resource.data).affectedKeys() &&
        (request.auth.uid in request.resource.data.friends || 
         request.auth.uid in resource.data.friends);
      
      // Allow updating following array (user adds someone they want to follow to their own following list)
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        'following' in request.resource.data.diff(resource.data).affectedKeys();
      
      // Allow updating followers array (someone else adds themselves to this user's followers list)
      allow update: if request.auth != null && 
        'followers' in request.resource.data.diff(resource.data).affectedKeys();
      
      // Allow updating gamification fields for the user's own profile
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        (
          'totalPosts' in request.resource.data.diff(resource.data).affectedKeys() ||
          'totalLikes' in request.resource.data.diff(resource.data).affectedKeys() ||
          'totalComments' in request.resource.data.diff(resource.data).affectedKeys() ||
          'xp' in request.resource.data.diff(resource.data).affectedKeys() ||
          'level' in request.resource.data.diff(resource.data).affectedKeys() ||
          'achievements' in request.resource.data.diff(resource.data).affectedKeys() ||
          'dailyStreak' in request.resource.data.diff(resource.data).affectedKeys() ||
          'lastLoginDate' in request.resource.data.diff(resource.data).affectedKeys() ||
          'lastDailyQuestDate' in request.resource.data.diff(resource.data).affectedKeys() ||
          'dailyQuestAssignedDate' in request.resource.data.diff(resource.data).affectedKeys() ||
          'dailyQuestCompletedDate' in request.resource.data.diff(resource.data).affectedKeys() ||
          'activeDailyQuest' in request.resource.data.diff(resource.data).affectedKeys() ||
          'totalFriends' in request.resource.data.diff(resource.data).affectedKeys() ||
          'totalFollowers' in request.resource.data.diff(resource.data).affectedKeys() ||
          'totalFollowing' in request.resource.data.diff(resource.data).affectedKeys()
        );
      
      // Allow updating notification settings for the user's own profile
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        (
          'pushToken' in request.resource.data.diff(resource.data).affectedKeys() ||
          'notificationsEnabled' in request.resource.data.diff(resource.data).affectedKeys() ||
          'webNotificationsEnabled' in request.resource.data.diff(resource.data).affectedKeys()
        );

      // Admin can delete users for moderation
      allow delete: if isAdmin();
    }
    
    // Posts - users can create their own posts, everyone can read posts
    match /posts/{postId} {
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || // Owner can update
         'likes' in request.resource.data.diff(resource.data).affectedKeys() || // Anyone can like
         'likedBy' in request.resource.data.diff(resource.data).affectedKeys() || // Anyone can like
         'comments' in request.resource.data.diff(resource.data).affectedKeys()); // Comments count update
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    // Comments - users can create comments, read all comments, update/delete their own
    match /comments/{commentId} {
      allow create: if request.auth != null && 
        (request.resource.data.userId == request.auth.uid || 
         request.auth.uid == request.resource.data.userId);
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || // Owner can update
         'likes' in request.resource.data.diff(resource.data).affectedKeys() || // Anyone can like
         'likedBy' in request.resource.data.diff(resource.data).affectedKeys() || // Anyone can like
         'repliesCount' in request.resource.data.diff(resource.data).affectedKeys()); // Replies count update
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    // Replies - users can create replies, read all replies, update/delete their own
    match /replies/{replyId} {
      allow create: if request.auth != null && 
        (request.resource.data.userId == request.auth.uid ||
         request.auth.uid == request.resource.data.userId);
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || // Owner can update
         'likes' in request.resource.data.diff(resource.data).affectedKeys() || // Anyone can like
         'likedBy' in request.resource.data.diff(resource.data).affectedKeys()); // Anyone can like
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    // Tags - anyone can read, system can create/update (via posts service), admins can delete
    match /tags/{tagId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
    
    // Friend requests
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.fromUserId;
      allow read, update: if request.auth != null && 
        (request.auth.uid == resource.data.fromUserId || 
         request.auth.uid == resource.data.toUserId ||
         isAdmin());
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.fromUserId ||
         request.auth.uid == resource.data.toUserId ||
         isAdmin());
    }
    
    // Conversations
    match /conversations/{conversationId} {
      allow read: if request.auth != null && 
        (resource == null || 
         request.auth.uid in resource.data.participants ||
         'system_bot_assistant' in resource.data.participants); // Allow bot conversations
      
      allow create: if request.auth != null && 
        (request.auth.uid in request.resource.data.participants ||
         'system_bot_assistant' in request.resource.data.participants); // Allow creating bot conversations
      
      allow update: if request.auth != null && 
        (resource == null ||
         request.auth.uid in resource.data.participants ||
         request.auth.uid in request.resource.data.participants ||
         'system_bot_assistant' in resource.data.participants ||
         'system_bot_assistant' in request.resource.data.participants); // Allow bot conversations
      
      allow delete: if request.auth != null && 
        request.auth.uid in resource.data.participants;
    }
    
    // Direct messages
    match /directMessages/{messageId} {
      allow create: if request.auth != null && 
        (request.auth.uid == request.resource.data.fromUserId ||
         request.resource.data.fromUserId == 'system_bot_assistant' || // Allow bot messages
         request.resource.data.toUserId == 'system_bot_assistant'); // Allow messages to bot
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.toUserId; // For marking as read
    }
    
    // Moderation logs - admins and system can create, admins can read
    match /moderationLogs/{logId} {
      allow create: if isAdmin();
      allow read: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.reportedBy;
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.reportedBy || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow delete: if isAdmin();
      allow list: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Notifications - users can read their own notifications, system can create
    match /notifications/{notificationId} {
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Push Notifications - system can create, used for triggering push via Cloud Functions
    match /pushNotifications/{pushId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Only Cloud Functions should access
    }
  }
}