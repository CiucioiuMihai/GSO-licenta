rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // Any authenticated user can read any user profile (for viewing profiles, search, posts)
      allow read: if request.auth != null;
      
      // Only the user can write to their own user document
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow updating friends array when accepting friend requests
      allow update: if request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) &&
        (request.auth.uid in request.resource.data.friends || 
         request.auth.uid in resource.data.friends);
      
      // Allow updating following array (user adds someone they want to follow to their own following list)
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following']);
      
      // Allow updating followers array (someone else adds themselves to this user's followers list)
      allow update: if request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']);
      
      // Allow updating post count
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPosts']);
      
      // Allow updating multiple gamification fields
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPosts', 'totalLikes', 'totalComments', 'xp', 'level', 'achievements', 'dailyStreak', 'lastLoginDate', 'totalFriends', 'totalFollowers', 'totalFollowing']);
    }
    
    // Posts - users can create their own posts, everyone can read posts
    match /posts/{postId} {
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || // Owner can update
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) || // Anyone can like
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments'])); // Comments count update
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Comments - users can create comments, read all comments, update/delete their own
    match /comments/{commentId} {
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || // Owner can update
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) || // Anyone can like
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['repliesCount'])); // Replies count update
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Replies - users can create replies, read all replies, update/delete their own
    match /replies/{replyId} {
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || // Owner can update
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy'])); // Anyone can like
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Tags - anyone can read, system can create/update (via posts service)
    match /tags/{tagId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
    
    // Friend requests
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.fromUserId;
      allow read, update: if request.auth != null && 
        (request.auth.uid == resource.data.fromUserId || 
         request.auth.uid == resource.data.toUserId);
    }
    
    // Conversations
    match /conversations/{conversationId} {
      allow read: if request.auth != null && 
        (resource == null || 
         request.auth.uid in resource.data.participants ||
         'system_bot_assistant' in resource.data.participants); // Allow bot conversations
      allow write: if request.auth != null && 
        (resource == null || 
         request.auth.uid in resource.data.participants ||
         'system_bot_assistant' in resource.data.participants); // Allow bot conversations
      allow create: if request.auth != null && 
        (request.auth.uid in request.resource.data.participants ||
         'system_bot_assistant' in request.resource.data.participants); // Allow creating bot conversations
    }
    
    // Direct messages
    match /directMessages/{messageId} {
      allow create: if request.auth != null && 
        (request.auth.uid == request.resource.data.fromUserId ||
         request.resource.data.fromUserId == 'system_bot_assistant' || // Allow bot messages
         request.resource.data.toUserId == 'system_bot_assistant'); // Allow messages to bot
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.toUserId; // For marking as read
    }
  }
}